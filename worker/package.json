{
  "name": "day1design-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "node --test tests/*.test.mjs",
    "d1:migrate": "wrangler d1 execute day1design --remote --file=migrations/0001_init.sql",
    "d1:migrate:analytics": "wrangler d1 execute day1design --remote --file=migrations/0002_analytics_snapshots.sql",
    "d1:migrate:messages": "wrangler d1 execute day1design --remote --file=migrations/0006_messages.sql",
    "d1:migrate:messages:local": "wrangler d1 execute day1design --local --file=migrations/0006_messages.sql",
    "d1:migrate:marketing-archive": "wrangler d1 execute day1design --remote --file=migrations/0009_marketing_archive.sql",
    "d1:migrate:marketing-archive:local": "wrangler d1 execute day1design --local --file=migrations/0009_marketing_archive.sql",
    "d1:migrate:local": "wrangler d1 execute day1design --local --file=migrations/0001_init.sql",
    "d1:export": "wrangler d1 export day1design --remote --output=_export/d1-backup.sql",
    "secret:admin-password": "wrangler secret put ADMIN_PASSWORD",
    "secret:jwt": "wrangler secret put JWT_SECRET",
    "secret:meta-lead": "wrangler secret put META_LEAD_SECRET"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
